# Alnitar — copy to .env and fill in your values.
# Supabase (when not using Cloudflare backend)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# Cloudflare Worker backend (optional)
# VITE_CF_API_URL=https://your-worker.workers.dev

# Pro feature testing: comma-separated emails treated as Pro (no payment)
# VITE_PRO_EMAILS=you@example.com

# Stripe: never commit secret keys. Use Workers secrets: wrangler secret put STRIPE_SECRET_KEY
# Frontend only needs publishable key if using Stripe.js; Checkout redirect uses backend.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_... or pk_test_...
